          "raw": "{{api_url}}/vacancies/{{vacancy_id}}",
          "host": ["{{api_url}}"],
          "path": ["vacancies", "{{vacancy_id}}"]
        }
      }
    },
    {
      "name": "Validation Test - Missing Required Fields",
      "event": [
